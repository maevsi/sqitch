{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "customManagers": [
    {
      "customType": "regex",
      "datasourceTemplate": "deb",
      "fileMatch": [
        "\\.github/workflows/.*\\.ya?ml$"
      ],
      "matchStrings": [
        "#\\s+renovate:\\s+datasource=deb\\s+depName=(?<depName>\\S+)\\s+suite=(?<suite>\\S+)\\s+\\w+_\\w+:\\s+(?<currentValue>[^\\n]+)"
      ],
      "registryUrlTemplate": "https://archive.ubuntu.com/ubuntu?suite={{#if suite }}{{suite}}{{else}}stable{{/if}}&components=main,multiverse,restricted,universe&binaryArch=amd64"
    }
  ],
  "extends": [
    "github>dargmuesli/renovate-config"
  ]
}
